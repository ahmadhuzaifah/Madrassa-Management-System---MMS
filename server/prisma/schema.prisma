generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                  @id @default(cuid())
  name                 String
  email                String                  @unique
  passwordHash         String
  role                 String                  @default("USER")
  status               String                  @default("ACTIVE")
  emailVerified        Boolean                 @default(false)
  avatarUrl            String?
  phone                String?
  lastLoginAt          DateTime?
  sessionVersion       Int                     @default(0)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  settings             Setting?
  subscriptions        Subscription[]
  notifications        Notification[]
  activityLogs         ActivityLog[]
  files                FileUpload[]
  resetTokens          PasswordResetToken[]
  verificationTokens   EmailVerificationToken[]
  organizationMembers  OrganizationMember[]
  roleAssignments      RoleAssignment[]
  @@index([email])
}

model Setting {
  id                    String   @id @default(cuid())
  userId                String   @unique
  theme                 String   @default("dark")
  notificationsEnabled  Boolean  @default(true)
  timezone              String   @default("UTC")
  language              String   @default("en")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Organization {
  id              String                @id @default(cuid())
  name            String
  logoUrl         String?
  contactEmail    String?
  contactPhone    String?
  address         String?
  timezone        String                @default("UTC")
  currency        String                @default("USD")
  language        String                @default("en")
  primaryColor    String                @default("#0f172a")
  secondaryColor  String                @default("#2563eb")
  appearance      String                @default("system")
  ownerId         String
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  members         OrganizationMember[]
  invitations     OrganizationInvitation[]
  madrassas       Madrassa[]
  @@index([ownerId])
}

model OrganizationMember {
  id              String        @id @default(cuid())
  organizationId   String
  userId          String
  role            String        @default("MEMBER")
  createdAt       DateTime      @default(now())
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([organizationId, userId])
}

model OrganizationInvitation {
  id              String        @id @default(cuid())
  organizationId   String
  email           String
  token           String        @unique
  role            String        @default("MEMBER")
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdAt       DateTime      @default(now())
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  @@index([organizationId, email])
}

model Plan {
  id                String         @id @default(cuid())
  name              String
  slug              String         @unique
  description       String
  priceMonthly      Int
  priceYearly       Int
  trialDays         Int            @default(14)
  maxUsers          Int            @default(5)
  maxProjects       Int            @default(20)
  storageLimitGb    Int            @default(100)
  features          String
  stripePriceId     String?
  isActive          Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  subscriptions     Subscription[]
}

model Subscription {
  id                   String                @id @default(cuid())
  userId               String
  planId               String
  status               String                 @default("TRIAL")
  interval             String                 @default("MONTHLY")
  currentPeriodStart   DateTime              @default(now())
  currentPeriodEnd     DateTime
  trialEndsAt          DateTime?
  cancelAtPeriodEnd    Boolean               @default(false)
  stripeSubscriptionId String?
  lastInvoiceId        String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                 Plan                  @relation(fields: [planId], references: [id], onDelete: Restrict)
  invoices             Invoice[]
  @@index([userId])
}

model Invoice {
  id              String        @id @default(cuid())
  subscriptionId  String
  amount          Int
  currency        String        @default("usd")
  status          String        @default("paid")
  invoiceNumber   String
  issuedAt        DateTime      @default(now())
  pdfUrl          String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  subscription    Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  title       String
  message     String
  type        String   @default("info")
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, isRead])
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  entityType  String
  entityId    String?
  metadata    String?
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  @@index([userId, createdAt])
}

model FileUpload {
  id            String   @id @default(cuid())
  userId        String?
  originalName  String
  storedName    String
  mimeType      String
  sizeBytes     Int
  path          String
  createdAt     DateTime @default(now())
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  @@index([userId])
}

model PasswordResetToken {
  id          String    @id @default(cuid())
  userId      String
  token       String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailVerificationToken {
  id          String    @id @default(cuid())
  userId      String
  token       String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Role {
  id             String            @id @default(cuid())
  name           String
  slug           String            @unique
  description    String?
  isSystem       Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  permissions    RolePermission[]
  assignments    RoleAssignment[]
}

model Permission {
  id             String            @id @default(cuid())
  code           String            @unique
  resource       String
  action         String
  description    String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  roles          RolePermission[]
}

model RolePermission {
  id             String        @id @default(cuid())
  roleId         String
  permissionId   String
  createdAt      DateTime      @default(now())
  role           Role          @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission     Permission    @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  @@unique([roleId, permissionId])
}

model RoleAssignment {
  id             String        @id @default(cuid())
  userId         String
  roleId         String
  createdAt      DateTime      @default(now())
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           Role          @relation(fields: [roleId], references: [id], onDelete: Cascade)
  @@unique([userId])
}

model AdminSetting {
  id             String   @id @default(cuid())
  key            String   @unique
  value          String
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
}

model Madrassa {
  id                String        @id @default(cuid())
  organizationId    String
  name              String
  logoUrl           String?
  registrationNo    String?
  address           String?
  phone             String?
  email             String?
  website           String?
  principalName     String?
  establishmentYear Int?
  description       String?
  isDeleted         Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  organization      Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branches          Branch[]
  academicYears     AcademicYear[]
  departments       Department[]
  programs          Program[]
  classes           ClassRoom[]
  sections          Section[]
  subjects          Subject[]
  timetables        Timetable[]
  students          Student[]
  guardians         Guardian[]
  studentSequences  StudentSequence[]
  @@index([organizationId])
}

model Branch {
  id              String        @id @default(cuid())
  madrassaId      String
  name            String
  address         String?
  contactInfo     String?
  managerName     String?
  isActive        Boolean       @default(true)
  isDeleted       Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  madrassa        Madrassa      @relation(fields: [madrassaId], references: [id], onDelete: Cascade)
  classes         ClassRoom[]
  timetables      Timetable[]
  @@index([madrassaId])
}

model AcademicYear {
  id            String        @id @default(cuid())
  madrassaId    String
  name          String
  startDate     DateTime
  endDate       DateTime
  status        String        @default("ACTIVE")
  isDeleted     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  madrassa      Madrassa      @relation(fields: [madrassaId], references: [id], onDelete: Cascade)
  classes       ClassRoom[]
  @@index([madrassaId, status])
}

model Department {
  id            String        @id @default(cuid())
  madrassaId    String
  name          String
  description   String?
  isActive      Boolean       @default(true)
  isDeleted     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  madrassa      Madrassa      @relation(fields: [madrassaId], references: [id], onDelete: Cascade)
  programs      Program[]
  @@index([madrassaId])
}

model Program {
  id            String        @id @default(cuid())
  madrassaId    String
  departmentId  String
  name          String
  duration      String?
  description   String?
  status        String        @default("ACTIVE")
  isDeleted     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  madrassa      Madrassa      @relation(fields: [madrassaId], references: [id], onDelete: Cascade)
  department    Department    @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  classes       ClassRoom[]
  subjects      Subject[]
  @@index([madrassaId, departmentId])
}

model ClassRoom {
  id            String        @id @default(cuid())
  madrassaId    String
  programId     String
  academicYearId String
  branchId      String?
  teacherName   String?
  name          String
  capacity      Int?
  isActive      Boolean       @default(true)
  isDeleted     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  madrassa      Madrassa      @relation(fields: [madrassaId], references: [id], onDelete: Cascade)
  program       Program       @relation(fields: [programId], references: [id], onDelete: Restrict)
  academicYear  AcademicYear  @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  branch        Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  sections      Section[]
  subjects      Subject[]
  timetables    Timetable[]
  @@index([madrassaId, programId])
}

model Section {
  id            String        @id @default(cuid())
  madrassaId    String
  classRoomId   String
  name          String
  room          String?
  isActive      Boolean       @default(true)
  isDeleted     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  madrassa      Madrassa      @relation(fields: [madrassaId], references: [id], onDelete: Cascade)
  classRoom     ClassRoom     @relation(fields: [classRoomId], references: [id], onDelete: Cascade)
  @@index([madrassaId, classRoomId])
}

model Subject {
  id            String        @id @default(cuid())
  madrassaId    String
  programId     String
  classRoomId   String?
  name          String
  code          String?
  isActive      Boolean       @default(true)
  isDeleted     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  madrassa      Madrassa      @relation(fields: [madrassaId], references: [id], onDelete: Cascade)
  program       Program       @relation(fields: [programId], references: [id], onDelete: Restrict)
  classRoom     ClassRoom?    @relation(fields: [classRoomId], references: [id], onDelete: SetNull)
  timetables    Timetable[]
  @@index([madrassaId, programId])
}

model Timetable {
  id            String        @id @default(cuid())
  madrassaId    String
  branchId      String?
  classRoomId   String
  subjectId     String
  teacherName   String?
  day           String
  timeSlot      String
  isActive      Boolean       @default(true)
  isDeleted     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  madrassa      Madrassa      @relation(fields: [madrassaId], references: [id], onDelete: Cascade)
  branch        Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  classRoom     ClassRoom     @relation(fields: [classRoomId], references: [id], onDelete: Cascade)
  subject       Subject       @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  @@index([madrassaId, branchId, classRoomId])
}

model Guardian {
  id            String        @id @default(cuid())
  madrassaId    String
  name          String
  relationship  String
  phone         String?
  email         String?
  address       String?
  occupation    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  madrassa      Madrassa      @relation(fields: [madrassaId], references: [id], onDelete: Cascade)
  students      Student[]
  @@index([madrassaId])
}

model StudentSequence {
  id            String   @id @default(cuid())
  madrassaId    String
  year          Int
  sequence      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  madrassa      Madrassa @relation(fields: [madrassaId], references: [id], onDelete: Cascade)
  @@unique([madrassaId, year])
}

model Student {
  id                String        @id @default(cuid())
  madrassaId        String
  guardianId        String?
  registrationNumber String        @unique
  admissionNumber   String?
  fullName          String
  fatherName        String?
  grandfatherName   String?
  dateOfBirth       DateTime?
  gender            String?
  photo             String?
  phone             String?
  guardianPhone     String?
  email             String?
  address           String?
  city              String?
  province          String?
  branchId          String?
  departmentId      String?
  programId         String?
  classRoomId       String?
  sectionId         String?
  academicYearId    String?
  status            String        @default("ACTIVE")
  admissionDate     DateTime      @default(now())
  isDeleted         Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  madrassa          Madrassa      @relation(fields: [madrassaId], references: [id], onDelete: Cascade)
  guardian          Guardian?     @relation(fields: [guardianId], references: [id], onDelete: SetNull)
  documents         StudentDocument[]
  transfers         StudentTransfer[]
  @@index([madrassaId, status])
}

model StudentDocument {
  id            String   @id @default(cuid())
  studentId     String
  documentName  String
  fileUrl       String
  uploadedAt    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  @@index([studentId])
}

model StudentTransfer {
  id                String   @id @default(cuid())
  studentId         String
  previousBranchId  String?
  newBranchId       String?
  previousClassRoomId String?
  newClassRoomId    String?
  transferDate      DateTime @default(now())
  reason            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  student           Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  @@index([studentId, transferDate])
}
